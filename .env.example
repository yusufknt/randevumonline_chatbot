# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URL=
MONGODB_DB=randevum_chatbot

# ── Meta App Secret'leri ──────────────────────────────────────────────────────
# WA: developers.facebook.com/apps → App settings → Basic → App secret → Show
WA_APP_SECRET=
# IG: developers.facebook.com/apps → Instagram → API setup with Instagram Business Login
#     → "Instagram app secret" → Show  (Facebook App Secret'tan FARKLIDIR)
IG_APP_SECRET=

# ── Webhook Verify Token'ları ── terminal: openssl rand -hex 16  (her kanal için ayrı)
WA_VERIFY_TOKEN=
IG_VERIFY_TOKEN=

# ── WhatsApp Flow RSA Anahtarları ── terminal: python -m scripts gen-keys
# Public key'i Meta'ya yüklemek için: python -m scripts upload-key
WA_FLOW_PRIVATE_KEY_PATH=secrets/flow_private.pem
WA_FLOW_PRIVATE_KEY=
WA_FLOW_PRIVATE_KEY_PASSPHRASE=

# ── WhatsApp Flow Modu ── "draft" = DRAFT Flow'u CTA olarak gönder | boş = yalnız PUBLISHED
WA_FLOW_MODE=

# ── Flow Builder Preview tenant ── business_id | boş → berber_mehmet_kutahya
WA_FLOW_PREVIEW_BUSINESS_SLUG=

# ── Public URL ── terminal: ngrok http 8000 → Forwarding satırındaki HTTPS URL
PUBLIC_BASE_URL=

# ── Tenant — Berber Mehmet Kütahya ────────────────────────────────────────────
# WA token (24 sa): developers.facebook.com/apps → WhatsApp → Step 1 → Generate token
# WA kalıcı: business.facebook.com → Business Settings → System Users → Generate Token
# IG token: developers.facebook.com/apps → Instagram → API setup with Instagram business login
# Phone Number ID + WABA ID: developers.facebook.com/apps → WhatsApp → Step 1. Try it out
WA_BERBER_MEHMET_KUTAHYA_ACCESS_TOKEN=
IG_BERBER_MEHMET_KUTAHYA_ACCESS_TOKEN=
WA_BERBER_MEHMET_KUTAHYA_PHONE_NUMBER_ID=
WA_BERBER_MEHMET_KUTAHYA_WABA_ID=

# ── AI — Instagram "Müşteri Temsilcisi" (Groq) ────────────────────────────────
# Groq API key (ücretsiz): console.groq.com/keys
# AI_ENABLED=true iken IG ana menüdeki "Müşteri Temsilcisi" butonu AI sohbeti açar;
# AI işletmenin DB bilgilerine (hizmet/fiyat/saat/konum/personel/müsaitlik) göre yanıtlar.
# false iken buton eski davranışına (telefon numarası) düşer.
AI_ENABLED=false
GROQ_API_KEY=
# OpenAI-uyumlu endpoint. Groq dışı bir sağlayıcı/Ollama için değiştirilebilir.
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile
AI_REQUEST_TIMEOUT_S=30
AI_MAX_TOOL_ITERATIONS=5
CONVERSATION_HISTORY_TURNS=8
BOOKING_SESSION_CACHE_TTL_S=120
BOOKING_SESSION_CACHE_MAX_SESSIONS=2000
BOOKING_SESSION_CACHE_MAX_ENTRIES=256
REDIS_URL=redis://127.0.0.1:6379/0
VOICE_CACHE_SESSION_TTL_S=600
VOICE_CACHE_CATALOG_TTL_S=60
VOICE_CACHE_REDIS_TIMEOUT_S=0.1

# ── FastAPI ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── DeepSeek AI (Ses Modülü / Voice Bot) ─────────────────────────────────────
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
VOICE_MAX_CALL_DURATION_S=600
VOICE_MAX_TURNS=40
VOICE_SESSION_TIMEOUT_S=900

# ── Voice API (TTS) ──────────────────────────────────────────────────────────
# Netscape cookie jar yolu (curl -b cookies.txt ile aynı davranış).
TTS_COOKIE_FILE=cookies.txt
# Cookie dosyası yoksa authorization cookie değeri olarak kullanılabilir.
TTS_API_KEY=
TTS_API_GENDER=erkek
TTS_API_EMOTION=motivasyon
TTS_API_BASE_URL=https://voiceapi.createupload.com
VOICE_AGI_HOST=127.0.0.1
VOICE_AGI_PORT=4573
VOICE_AUDIOSOCKET_HOST=127.0.0.1
VOICE_AUDIOSOCKET_PORT=9019
VOICE_HEALTH_HOST=127.0.0.1
VOICE_HEALTH_PORT=9020
VOICE_MAX_CONCURRENT_CALLS=3
VOICE_GREETING_PCM=app/voice/assets/greeting.wav
VOICE_OPENING_PCM=app/voice/assets/opening.wav
VOICE_BOOKING_SUCCESS_PCM=app/voice/assets/booking_success.wav
VOICE_STT_FAST_MODEL=small
VOICE_STT_ACCURATE_MODEL=small
VOICE_STT_ACCURATE_CONFIDENCE_THRESHOLD=0.60
VOICE_STT_CONTEXT_RETRY_CONFIDENCE=0.45
VOICE_STT_MIN_ACTIONABLE_CONFIDENCE=0.30
VOICE_STT_ABSOLUTE_MIN_CONFIDENCE=0.15
VOICE_MAX_PENDING_UTTERANCES=4
VOICE_VAD_START_PROBABILITY=0.50
VOICE_VAD_BARGE_PROBABILITY=0.60
VOICE_VAD_START_MS=64
VOICE_VAD_BARGE_MS=128
VOICE_VAD_END_SILENCE_MS=576
VOICE_VAD_ENERGY_FLOOR=250
VOICE_VAD_BARGE_ENERGY_FLOOR=450
VOICE_SERVER_HOST=0.0.0.0
VOICE_SERVER_PORT=8010
# Netgsm WireGuard SIP kaynağı; birden fazlaysa virgülle ayırın.
VOICE_SIP_ALLOWED_HOSTS=10.203.0.1
# NAT arkasında ve Netgsm özel ağı dışında kullanılıyorsa dış medya IP'si.
# VOICE_EXTERNAL_IP=31.223.119.107
RTP_START_PORT=10000
RTP_END_PORT=10100
VOICE_RTP_ECHO_CORRELATION=0.70
VOICE_RTP_ECHO_WINDOW_MS=1200
